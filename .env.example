# Telegram bot token — BotFather se lo
BOT_TOKEN=your_bot_token_here

# Redis URL
REDIS_URL=redis://localhost:6379

# Webhook (production mein set karo, dev mein khali rakhna)
WEBHOOK_URL=https://yourdomain.com
PORT=8443

# ─────────────────────────────────────────
# TERABOX COOKIE — ZAROORI HAI
# ─────────────────────────────────────────
# Kaise nikalo:
#   1. Chrome mein terabox.com kholo aur login karo
#   2. F12 → Application → Cookies → https://www.terabox.com
#   3. "ndus" aur "lang" ki values copy karo
#   4. Neeche format mein paste karo:
TERABOX_COOKIE=lang=en; ndus=PASTE_NDUS_VALUE_HERE
